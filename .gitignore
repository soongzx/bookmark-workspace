# Chrome 扩展 - Git 忽略配置

# ====================
# 操作系统文件
# ====================
.DS_Store
Thumbs.db
desktop.ini

# ====================
# IDE 和编辑器配置
# ====================
.vscode/
.idea/
*.swp
*.swo
*~

# ====================
# 日志文件
# ====================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====================
# 环境和敏感信息
# ====================
.env
.env.local
.env.*.local
*.pem
*.key
*.cert

# ====================
# 构建输出 (如果有)
# ====================
dist/
!dist/*.crx
build/
*.zip

# ====================
# 依赖包(如果有)
# ====================
node_modules/
package-lock.json
yarn.lock

# ====================
# 测试覆盖率报告
# ====================
coverage/
.nyc_output/

# ====================
# 临时文件
# ====================
*.tmp
*.temp
.cache/

# ====================
# 可选:图标文件(如需自行准备)
# ====================
# icons/*.png
# !icons/.gitkeep
