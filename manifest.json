{
    "manifest_version": 3,
    "name": "Bookmark Workspace Manager",
    "version": "2.7",
    "description": "以workspace方式管理书签，支持多列树状展示、多主题、双面板对比与状态记忆",
    "permissions": ["bookmarks", "storage"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "📑 书签工作区"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}